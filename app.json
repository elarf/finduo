{
  "expo": {
    "name": "finduo",
    "slug": "elarf",
    "version": "1.6.2",
    "orientation": "portrait",
    "icon": "./public/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "finduo",
    "splash": {
      "image": "./public/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.finduo.app"
    },
    "android": {
      "package": "com.finduo.app",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./public/icon.png",
        "backgroundImage": "./public/icon-maskable.png",
        "monochromeImage": "./public/icon-maskable.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./public/icon.png",
      "output": "single",
      "name": "Finduo",
      "shortName": "Finduo",
      "description": "Financial tracking app for couples",
      "themeColor": "#53E3A6",
      "backgroundColor": "#060A14",
      "display": "standalone",
      "orientation": "portrait",
      "startUrl": "/"
    },
    "extra": {
      "eas": {
        "projectId": "a9bb1fc5-8ce5-4722-8056-31a965a95a31"
      }
    },
    "owner": "elarf8769",
    "plugins": [
      "react-native-health-connect"
    ]
  }
}
